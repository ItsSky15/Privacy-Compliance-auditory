{
  "manifest_version": 3,
  "name": "Privacy Guardian",
  "version": "1.0",
  "description": "Analyze website privacy and security in seconds",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
